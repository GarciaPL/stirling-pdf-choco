  <metadata>
    <id>stirling-pdf</id>
    <version>2.14.2</version>
    <packageSourceUrl>https://github.com/TODO-your-handle/stirling-pdf-choco</packageSourceUrl>
    <owners>TODO-your-handle</owners>
    <title>Stirling PDF</title>
    <authors>Stirling-Tools</authors>
    <projectUrl>https://www.stirlingpdf.com/</projectUrl>
    <iconUrl>https://raw.githubusercontent.com/Stirling-Tools/Stirling-PDF/main/frontend/public/favicon.svg</iconUrl>
    <copyright>Stirling-Tools</copyright>
    <licenseUrl>https://github.com/Stirling-Tools/Stirling-PDF/blob/main/LICENSE</licenseUrl>
